# === Faraday — .gitignore (Expo / React Native) ===

# Dependencies (5+ GB — never commit)
node_modules/
.pnp
.pnp.js

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Native projects — regenerated by `expo prebuild --clean`
/android
/ios
*.orig.*

# Model weights — large; downloaded by the SDK or sideloaded separately, never committed
assets/models/**/*.gguf
assets/models/**/*.bin
assets/models/**/*.onnx
assets/models/**/*.safetensors

# Environment / secrets (keep .env.example, ignore real envs)
.env
.env*.local

# Signing / service files
*.jks
*.keystore
!debug.keystore
google-services.json
GoogleService-Info.plist

# Logs & debug
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Build / cache artifacts
*.tsbuildinfo
/coverage

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
*.pem

# Ignore markdown files (keep README for submission)
*.md
!README.md
